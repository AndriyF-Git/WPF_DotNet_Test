<Page x:Class="WPF_DotNet_Test.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WPF_DotNet_Test.Views"
      mc:Ignorable="d" 
      Background="{StaticResource BackgroundBrush}"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage">

    <Grid>
        <DockPanel Margin="24,20,24,0">

            <!-- Header -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                <TextBlock Text="Market Overview"
                           FontSize="24" FontWeight="SemiBold"/>
                <TextBlock Text="Top 50 cryptocurrencies by market cap"
                           FontSize="13"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Column Headers -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="#"
                           FontSize="11" Foreground="{StaticResource SecondaryTextBrush}"/>
                <TextBlock Grid.Column="2" Text="Name"
                           FontSize="11" Foreground="{StaticResource SecondaryTextBrush}"/>
                <TextBlock Grid.Column="3" Text="Price"
                           FontSize="11" Foreground="{StaticResource SecondaryTextBrush}"
                           HorizontalAlignment="Right"/>
                <TextBlock Grid.Column="4" Text="24h %"
                           FontSize="11" Foreground="{StaticResource SecondaryTextBrush}"
                           HorizontalAlignment="Right"/>
                <TextBlock Grid.Column="5" Text="Market Cap"
                           FontSize="11" Foreground="{StaticResource SecondaryTextBrush}"
                           HorizontalAlignment="Right"/>
            </Grid>

            <!-- Coin List -->
            <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Coins}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource CoinRowButtonStyle}"
                                    Command="{Binding DataContext.NavigateToCoinCommand,
                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Rank -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding MarketCapRank}"
                                               FontSize="13"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               VerticalAlignment="Center"/>

                                    <!-- Icon -->
                                    <Image Grid.Column="1"
                                           Source="{Binding Image}"
                                           Width="32" Height="32"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           VerticalAlignment="Center"/>

                                    <!-- Name + Symbol -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="4,0,0,0">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14" FontWeight="Medium"/>
                                        <TextBlock Text="{Binding Symbol}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                    </StackPanel>

                                    <!-- Price -->
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding CurrentPrice}"
                                               FontSize="14" FontWeight="Medium"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>

                                    <!-- 24h % -->
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding PriceChangePercentage24h, StringFormat='{}{0:F2}%'}"
                                               Foreground="{Binding PriceChangePercentage24h, Converter={StaticResource PriceChangeToBrushConverter}}"
                                               FontSize="13" FontWeight="Medium"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>

                                    <!-- Market Cap -->
                                    <TextBlock Grid.Column="5"
                                               Text="{Binding MarketCap}"
                                               FontSize="13"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- ── Loading Overlay ── -->
        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
              Background="#AA1E1E2E">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Spinner -->
                <Grid Width="50" Height="50" Margin="0,0,0,12">
                    <Ellipse Width="44" Height="44"
                             Stroke="#33FFFFFF"
                             StrokeThickness="4"/>
                    <Ellipse x:Name="SpinnerArc"
                             Width="44" Height="44"
                             Stroke="{StaticResource AccentBrush}"
                             StrokeThickness="4"
                             StrokeDashArray="20 50"
                             StrokeDashCap="Round">
                        <Ellipse.RenderTransform>
                            <RotateTransform CenterX="22" CenterY="22"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="RenderTransform.(RotateTransform.Angle)"
                                            From="0" To="360" Duration="0:0:1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </Grid>
                <TextBlock Text="Loading market data…"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           FontSize="14"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ── Error Banner ── -->
        <Border Visibility="{Binding HasStatusMessage, Converter={StaticResource BooleanToVisibilityConverter}}"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource NegativeBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,10"
                Margin="24"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Stretch">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource NegativeBrush}"
                       TextWrapping="Wrap"/>
        </Border>

    </Grid>
</Page>
