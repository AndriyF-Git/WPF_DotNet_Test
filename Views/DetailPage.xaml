<Page x:Class="WPF_DotNet_Test.Views.DetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="{DynamicResource BackgroundBrush}"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DetailPage">

    <Grid>
        <DockPanel Margin="24,20,24,0">

            <!-- Header -->
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                <Button DockPanel.Dock="Left"
                        Content="← Back"
                        Style="{DynamicResource GhostButtonStyle}"
                        Click="BackButton_Click"
                        VerticalAlignment="Top"
                        Margin="0,0,12,0"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="{Binding Coin.Image}"
                           Width="40" Height="40"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="{Binding Coin.Name}"
                                   FontSize="22" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Coin.Symbol}"
                                   FontSize="13"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>

            <!-- Stat cards -->
            <UniformGrid DockPanel.Dock="Top" Columns="4" Margin="0,0,0,16">
                <Border Style="{DynamicResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Price" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="{Binding Coin.CurrentPrice, StringFormat='${0:N2}'}" FontSize="16" FontWeight="Medium" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="24h Change" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="{Binding Coin.PriceChangePercentage24h, StringFormat='{}{0:F2}%'}"
                                   Foreground="{Binding Coin.PriceChangePercentage24h, Converter={StaticResource PriceChangeToBrushConverter}}"
                                   FontSize="16" FontWeight="Medium" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Market Cap" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="{Binding Coin.MarketCap, StringFormat='${0:N0}'}" FontSize="16" FontWeight="Medium" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="24h Volume" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="{Binding Coin.TotalVolume, StringFormat='${0:N0}'}" FontSize="16" FontWeight="Medium" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Markets header -->
            <TextBlock DockPanel.Dock="Top"
                       Text="Markets"
                       FontSize="16" FontWeight="SemiBold"
                       Margin="0,0,0,8"/>

            <!-- Tickers list -->
            <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Tickers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{DynamicResource CardStyle}" Padding="16,10" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="160"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Market.Name}"
                                               FontSize="14" FontWeight="Medium"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Last, StringFormat='${0:N2}'}"
                                               FontSize="13"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Volume, StringFormat='Vol: {0:N0}'}"
                                               FontSize="13"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- ── Loading Overlay ── -->
        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
              Background="#AA1E1E2E">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Width="50" Height="50" Margin="0,0,0,12">
                    <Ellipse Width="44" Height="44"
                             Stroke="#33FFFFFF"
                             StrokeThickness="4"/>
                    <Ellipse Width="44" Height="44"
                             Stroke="{DynamicResource AccentBrush}"
                             StrokeThickness="4"
                             StrokeDashArray="20 50"
                             StrokeDashCap="Round">
                        <Ellipse.RenderTransform>
                            <RotateTransform CenterX="22" CenterY="22"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="RenderTransform.(RotateTransform.Angle)"
                                            From="0" To="360" Duration="0:0:1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </Grid>
                <TextBlock Text="Loading coin data…"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="14"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ── Error Banner ── -->
        <Border Visibility="{Binding HasStatusMessage, Converter={StaticResource BooleanToVisibilityConverter}}"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource NegativeBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,10"
                Margin="24"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Stretch">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource NegativeBrush}"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Page>
