<Window x:Class="WPF_DotNet_Test.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_DotNet_Test.Views"
        mc:Ignorable="d"
        Title="CoinGecko API Client" Height="600" Width="800">
    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}">
            <DockPanel>

                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="20,30,20,40">
                    <TextBlock Text="₿ CryptoApp"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="Live Market Dashboard"
                               FontSize="11"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel DockPanel.Dock="Top">
                    <Button Content="Home"
                            Tag="🏠"
                            Style="{StaticResource NavButtonStyle}"/>

                    <Button Content="Search"
                            Tag="🔍"
                            Style="{StaticResource NavButtonStyle}"
                            IsEnabled="False"/>

                    <Button Content="Converter"
                            Tag="🔄"
                            Style="{StaticResource NavButtonStyle}"
                            IsEnabled="False"/>
                </StackPanel>

                <!-- Footer -->
                <TextBlock DockPanel.Dock="Bottom"
                           Text="Powered by CoinGecko"
                           FontSize="10"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>
            </DockPanel>
        </Border>

        <Frame Grid.Column="1"
               x:Name="MainFrame"
               NavigationUIVisibility="Hidden"/>

    </Grid>
</Window>
