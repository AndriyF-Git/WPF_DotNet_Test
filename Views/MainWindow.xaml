<Window x:Class="WPF_DotNet_Test.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_DotNet_Test.Views"
        mc:Ignorable="d"
        Title="CoinGecko API Client" Height="600" Width="800">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}">
            <DockPanel>

                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="20,30,20,40">
                    <TextBlock Text="₿ CryptoApp"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="Live Market Dashboard"
                               FontSize="11"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel DockPanel.Dock="Top">
                    <Button Content="Home"
                            Tag="🏠"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding GoHomeCommand}"/>

                    <Button Content="Search"
                            Tag="🔍"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding GoSearchCommand}"/>

                    <Button Content="Converter"
                            Tag="🔄"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding GoConverterCommand}"/>
                </StackPanel>

                <!-- Footer -->
                <TextBlock DockPanel.Dock="Bottom"
                           Text="Powered by CoinGecko"
                           FontSize="10"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1"
              Background="{StaticResource SidebarBrush}">
            <StackPanel Margin="20" VerticalAlignment="Stretch">
                <Button Command="{Binding LoadCoinsCommand}" 
                    Padding="10,8" 
                    FontSize="14"
                    Background="#007ACC"
                    Foreground="White"
                    Cursor="Hand">  
                    Load Coins
                </Button>

                <TextBlock Text="Loading..." 
                   Margin="0,15,0,0"
                   FontSize="12"
                   Foreground="White"
                   Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                </TextBlock>

                <TextBlock Text="{Binding StatusMessage}"
                   Visibility="{Binding HasStatusMessage, 
                   Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <ListView ItemsSource="{Binding Coins}"
                    Background="{StaticResource SidebarBrush}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" Width="150"/>
                                <TextBlock Text="{Binding Symbol}" Width="80"/>
                                <TextBlock Text="{Binding CurrentPrice, StringFormat='${0:F2}'}" Width="120"/>
                                <TextBlock Text="{Binding PriceChangePercentage24h, StringFormat='{}{0:F2}%'}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
