<Application x:Class="WPF_DotNet_Test.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WPF_DotNet_Test"
             xmlns:converters="clr-namespace:WPF_DotNet_Test.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <!--  CONVERTERS (theme-independent, always available)  -->
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:PriceChangeToBrushConverter x:Key="PriceChangeToBrushConverter"/>

            <!--  ACTIVE THEME (index 0 — swapped at runtime by the theme toggle)  -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
